{
  "name": "@geostrategists/react-router-sessions-dynamodb",
  "version": "0.0.1",
  "description": "AWS DynamoDB session storage for React Router",
  "homepage": "https://github.com/geostrategists/react-router-sessions-dynamodb#readme",
  "bugs": {
    "url": "https://github.com/geostrategists/react-router-sessions-dynamodb/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geostrategists/react-router-sessions-dynamodb.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt . '!**/*.yml' '!**/*.yaml'",
    "format:check": "oxfmt --check . '!**/*.yml' '!**/*.yaml'",
    "typecheck": "tsc --noEmit",
    "prepare": "lefthook install",
    "prepack": "pnpm build"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.767.0",
    "@aws-sdk/lib-dynamodb": "^3.767.0",
    "@types/node": "^25.2.3",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "react-router": "^7.3.0",
    "rimraf": "^6.1.2",
    "tsdown": "^0.22.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "react-router": "^7.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed"
}
